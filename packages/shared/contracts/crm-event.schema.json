{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/contracts/crm-event.schema.json",
  "title": "CrmEvent",
  "type": "object",
  "required": ["source", "externalRef", "eventType", "occurredAt", "payload"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "externalRef": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "eventType": {
      "type": "string",
      "enum": [
        "lead.created",
        "lead.updated",
        "opportunity.updated",
        "activity.logged",
        "policy.action_requested"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
